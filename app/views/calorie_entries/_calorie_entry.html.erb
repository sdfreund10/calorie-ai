<article id="<%= dom_id(calorie_entry) %>" class="rounded-xl border border-white/10 bg-[#0c0f15] p-3.5">
  <div class="mb-2 flex items-start justify-between gap-3">
    <div>
      <p class="text-sm font-semibold text-neutral-100"><%= calorie_entry.name.presence || "Untitled entry" %></p>
      <p class="mt-0.5 text-xs text-neutral-400">
        <%= calorie_entry.created_at.strftime("%-I:%M %p") %> · <%= calorie_entry.meal.humanize %>
      </p>
    </div>
    <p class="rounded-md border border-white/10 bg-white/[0.02] px-2 py-1 text-xs font-semibold text-neutral-200">
      <%= calorie_entry.calories %> cal
    </p>
  </div>

  <% if calorie_entry.note.present? %>
    <p class="text-sm leading-relaxed text-neutral-300/95"><%= calorie_entry.note %></p>
  <% end %>

  <% if calorie_entry.image.attached? %>
    <%= image_tag calorie_entry.image, class: "mt-3 h-24 w-24 rounded-lg border border-white/10 object-cover" %>
  <% end %>
</article>
