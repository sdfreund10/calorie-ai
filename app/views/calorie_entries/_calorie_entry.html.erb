<article
  id="<%= dom_id(calorie_entry) %>"
  class="flex items-center gap-2 rounded-lg border border-white/10 bg-[#0c0f15] px-2 py-1"
>
  <div class="shrink-0 min-w-[3.5rem] text-right tabular-nums leading-none">
    <span class="text-sm font-semibold text-neutral-100"><%= calorie_entry.calories %></span><span class="text-xs font-medium text-neutral-500"> cal</span>
  </div>

  <div class="flex min-w-0 flex-1 items-center gap-2">
    <span class="min-w-0 flex-1 truncate text-sm font-medium text-neutral-100">
      <%= calorie_entry.name.presence || "Untitled entry" %>
    </span>
    <span class="shrink-0 rounded-md border border-white/10 bg-white/[0.04] px-2 py-0.5 text-[11px] font-medium text-neutral-400">
      <%= calorie_entry.meal.humanize %>
    </span>
  </div>

  <div class="flex h-9 w-9 shrink-0 items-center justify-end">
    <% if calorie_entry.image.attached? %>
      <%= image_tag calorie_entry.image.variant(resize_to_limit: [48, 48]), class: "h-9 w-9 shrink-0 rounded-md border border-white/10 object-cover", alt: "" %>
    <% end %>
  </div>
</article>
