<%= form_with model: calorie_entry, url: log_entries_path(date: date), class: "space-y-3", data: { action: "turbo:submit-end->drawer#submitted" } do |form| %>
  <%= form.hidden_field :eaten_on, value: date %>

  <% if calorie_entry.errors.any? %>
    <div class="rounded-lg border border-red-900/50 bg-red-950/30 px-3 py-2 text-sm text-red-200">
      <p class="font-semibold">Could not save entry:</p>
      <ul class="mt-1 list-disc pl-5">
        <% calorie_entry.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, class: "mb-1 block text-sm font-medium text-neutral-300" %>
    <%= form.text_field :name, placeholder: "Dish name", class: "w-full rounded-md border border-white/10 bg-[#0c0f15] px-3 py-2.5 text-base text-neutral-100 placeholder:text-neutral-500 focus:border-blue-400/40 focus:outline-none focus:ring-1 focus:ring-blue-400/25" %>
  </div>

  <div>
    <%= form.label :meal, class: "mb-1 block text-sm font-medium text-neutral-300" %>
    <%= form.select :meal, CalorieEntry.meals.keys.map { |meal| [meal.humanize, meal] }, {}, class: "w-full rounded-md border border-white/10 bg-[#0c0f15] px-3 py-2.5 text-base text-neutral-100 focus:border-blue-400/40 focus:outline-none focus:ring-1 focus:ring-blue-400/25" %>
  </div>

  <div>
    <%= form.label :calories, class: "mb-1 block text-sm font-medium text-neutral-300" %>
    <%= form.number_field :calories, min: 1, step: 1, placeholder: "e.g. 450", class: "w-full rounded-md border border-white/10 bg-[#0c0f15] px-3 py-2.5 text-base text-neutral-100 placeholder:text-neutral-500 focus:border-blue-400/40 focus:outline-none focus:ring-1 focus:ring-blue-400/25" %>
  </div>

  <div>
    <%= form.label :note, class: "mb-1 block text-sm font-medium text-neutral-300" %>
    <%= form.text_area :note, rows: 3, placeholder: "Optional notes", class: "w-full rounded-md border border-white/10 bg-[#0c0f15] px-3 py-2.5 text-base text-neutral-100 placeholder:text-neutral-500 focus:border-blue-400/40 focus:outline-none focus:ring-1 focus:ring-blue-400/25" %>
  </div>

  <div>
    <%= form.label :image, class: "mb-1 block text-sm font-medium text-neutral-300" %>
    <%= form.file_field :image, accept: "image/*", class: "w-full rounded-md border border-white/10 bg-[#0c0f15] px-3 py-2 text-sm text-neutral-300 file:mr-3 file:rounded-md file:border-0 file:bg-white/10 file:px-3 file:py-2 file:text-neutral-100 hover:file:bg-white/15" %>
  </div>

  <%= form.submit "Save entry", class: "w-full rounded-md border border-white/15 bg-white/[0.06] px-4 py-3 text-sm font-semibold text-neutral-100 transition hover:border-white/25 hover:bg-white/[0.10] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/20 focus-visible:ring-offset-2 focus-visible:ring-offset-[#0f1117] active:scale-[0.99]" %>
<% end %>
