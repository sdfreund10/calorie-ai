<% if @calorie_entry.errors.any? %>
  <%= turbo_stream.replace "entry_form" do %>
    <%= turbo_frame_tag "entry_form" do %>
      <%= render "calorie_entries/drawer_chrome", title: "New entry" %>
      <% if @entry_from_photo_step %>
        <%= render "calorie_entries/photo_upload", date: @date, calorie_entry: @calorie_entry %>
      <% else %>
        <%= render "calorie_entries/form", calorie_entry: @calorie_entry, date: @date %>
      <% end %>
    <% end %>
  <% end %>
<% elsif @calorie_entry.draft? %>
  <%= turbo_stream.replace "entry_form" do %>
    <%= turbo_frame_tag "entry_form" do %>
      <%= render "calorie_entries/drawer_chrome", title: "New entry" %>
      <%= render "calorie_entries/form", calorie_entry: @calorie_entry, date: @date %>
    <% end %>
  <% end %>
<% else %>
  <%= turbo_stream.append "entries", partial: "calorie_entries/calorie_entry", locals: { calorie_entry: @calorie_entry } %>
  <%= turbo_stream.replace "entry_form" do %>
    <%= turbo_frame_tag "entry_form" do %>
      <%= render "calorie_entries/drawer_chrome", title: "New entry" %>
      <%= render "calorie_entries/photo_upload", date: @date, calorie_entry: CalorieEntry.new(eaten_on: @date, meal: :other) %>
    <% end %>
  <% end %>
<% end %>
