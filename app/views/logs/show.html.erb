<% content_for :title, "Log for #{@date}" %>

<section class="w-full min-h-screen bg-[#080a0f] text-neutral-100" data-controller="drawer" data-action="keydown.esc@window->drawer#close">
  <div class="mx-auto flex min-h-screen w-full max-w-3xl items-start justify-center px-4 py-10 sm:px-6">
    <div class="w-full max-w-2xl rounded-2xl border border-white/10 bg-[#0f1117] p-4 sm:p-6">
      <header class="mb-5 border-b border-white/10 pb-5">
        <p class="text-[11px] uppercase tracking-[0.18em] text-neutral-500">Daily log</p>
        <div class="mt-2 flex items-end justify-between gap-3">
          <h1 class="text-2xl font-semibold tracking-tight sm:text-3xl"><%= @date.strftime("%A, %b %-d") %></h1>
          <p class="rounded-md border border-white/10 bg-white/[0.02] px-2.5 py-1 text-xs font-medium text-neutral-300">
            <%= pluralize(@entries.size, "entry") %>
          </p>
        </div>
      </header>

      <% if flash[:alert].present? %>
        <p class="mb-3 rounded-xl border border-red-900/50 bg-red-950/30 px-3 py-2 text-sm text-red-200">
          <%= flash[:alert] %>
        </p>
      <% end %>

      <% if flash[:notice].present? %>
        <p class="mb-3 rounded-xl border border-emerald-900/50 bg-emerald-950/30 px-3 py-2 text-sm text-emerald-200">
          <%= flash[:notice] %>
        </p>
      <% end %>

      <div id="entries" class="space-y-2">
        <%= render @entries %>
      </div>

      <% if @entries.empty? %>
        <p class="mt-6 rounded-lg border border-white/10 bg-[#0c0e14] px-4 py-5 text-center text-sm text-neutral-400">
          No entries yet for this day.
        </p>
      <% end %>

      <div class="sticky bottom-0 mt-6 border-t border-white/10 bg-[#0f1117]/95 pt-4 backdrop-blur">
        <button
          type="button"
          class="w-full rounded-lg border border-white/15 bg-white/[0.06] px-5 py-3 text-sm font-semibold text-neutral-100 transition hover:border-white/25 hover:bg-white/[0.10] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/20 focus-visible:ring-offset-2 focus-visible:ring-offset-[#080a0f] active:scale-[0.99]"
          data-action="drawer#open"
        >
          Add Entry
        </button>
      </div>
    </div>
  </div>

  <div class="fixed inset-0 z-40 hidden" data-drawer-target="overlay">
    <button
      type="button"
      class="absolute inset-0 z-0 bg-black/55 backdrop-blur-[1px]"
      aria-label="Close entry drawer"
      data-action="drawer#close"
    ></button>

    <aside
      class="absolute right-0 top-0 z-10 h-full w-full border-l border-white/10 bg-[#0f1117] p-4 sm:max-w-md"
      style="background-color: #0f1117;"
      role="dialog"
      aria-modal="true"
    >
      <div class="mb-3 flex items-center justify-between">
        <h2 class="text-base font-semibold tracking-tight">New Entry</h2>
        <button
          type="button"
          class="rounded-md border border-white/15 px-2 py-1 text-xs text-neutral-300 transition hover:bg-white/10"
          data-action="drawer#close"
        >
          Close
        </button>
      </div>

      <%= turbo_frame_tag "entry_form" do %>
        <%= render "calorie_entries/form", calorie_entry: @calorie_entry, date: @date %>
      <% end %>
    </aside>
  </div>
</section>
